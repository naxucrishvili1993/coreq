# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=coreq
POSTGRES_PASSWORD=changeme
POSTGRES_DB=coreq

# ─── Backend ──────────────────────────────────────────────────────────────────
# Used locally (Docker overrides this with the postgres service hostname)
DATABASE_URL=postgresql://coreq:changeme@localhost:5432/coreq

JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
